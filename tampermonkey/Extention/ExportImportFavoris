// ==UserScript==
// @name         Sync Favoris - Récupération des données
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Récupère et affiche les dossiers et favoris depuis FavorisComposant
// @match        https://app.powerbi.com/groups/me/apps/*
// @match        https://app.powerbi.com/*/cvSandboxPack.cshtml*
// @grant        GM_getValue
// @grant        GM_setValue
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    // Vérifier si on est dans la page principale
    const isInIframe = window.self !== window.top;
    if (isInIframe) return;

    console.log('🔄 SyncFavoris - Démarrage...');

    // ===== FONCTIONS DE RÉCUPÉRATION DES DONNÉES =====
    
    function loadFavoris() {
        return GM_getValue('powerbi_favoris', []);
    }

    function loadFolders() {
        return GM_getValue('powerbi_folders', []);
    }

    function loadFoldersHierarchy() {
        return GM_getValue('powerbi_folders_hierarchy', {});
    }

    function loadCategories() {
        return GM_getValue('powerbi_categories', []);
    }

    // ===== FONCTION POUR EXTRAIRE LES DONNÉES DEPUIS LE DOM =====
    
    function extractDataFromDOM() {
        const componentsList = document.getElementById('components-list');
        if (!componentsList) {
            console.warn('⚠️ Liste des composants non trouvée dans le DOM');
            return null;
        }

        const dataByFolder = {};
        const componentCards = componentsList.querySelectorAll('.component-card');

        componentCards.forEach(card => {
            // Extraire le nom du composant
            const nameElement = card.querySelector('h4');
            const nom = nameElement ? nameElement.textContent.trim() : 'Inconnu';

            // Extraire la catégorie
            const categorie = card.getAttribute('data-categorie') || 'Sans catégorie';

            // Extraire les dossiers (badges bleus et violets)
            const folderBadges = card.querySelectorAll('div[style*="rgba(74,144,226"], div[style*="rgba(156,39,176"]');
            const folders = [];
            folderBadges.forEach(badge => {
                const folderText = badge.textContent.trim();
                if (folderText) folders.push(folderText);
            });

            // Extraire les repères (badges jaunes)
            const repereBadges = card.querySelectorAll('span[style*="rgba(255,193,7"]');
            const reperes = [];
            repereBadges.forEach(badge => {
                const repereText = badge.textContent.trim();
                if (repereText) reperes.push(repereText);
            });

            // Extraire le commentaire
            let commentaire = '';
            const commentaireDiv = card.querySelector('div[style*="💬 Commentaire"]');
            if (commentaireDiv) {
                const commentaireContent = commentaireDiv.querySelector('div[style*="white-space: pre-wrap"]');
                if (commentaireContent) {
                    commentaire = commentaireContent.textContent.trim();
                }
            }

            // Si aucun dossier, utiliser "Sans dossier"
            const foldersList = folders.length > 0 ? folders : ['Sans dossier'];

            // Créer une entrée pour chaque dossier
            foldersList.forEach(folderKey => {
                if (!dataByFolder[folderKey]) {
                    dataByFolder[folderKey] = {
                        folderInfo: { name: folderKey },
                        categories: {},
                        total: 0
                    };
                }

                const folderData = dataByFolder[folderKey];
                folderData.total++;

                if (!folderData.categories[categorie]) {
                    folderData.categories[categorie] = [];
                }

                folderData.categories[categorie].push({
                    nom: nom,
                    repere: reperes.join(', ') || '',
                    commentaire: commentaire,
                    allFolders: folders,
                    allReperes: reperes
                });
            });
        });

        return dataByFolder;
    }

    // ===== FONCTION POUR ORGANISER LES DONNÉES =====
    
    function organizeData() {
        // Essayer d'abord d'extraire depuis le DOM
        let dataByFolder = extractDataFromDOM();
        
        // Si pas de données dans le DOM, utiliser le stockage GM
        if (!dataByFolder || Object.keys(dataByFolder).length === 0) {
            console.log('📦 Utilisation des données du stockage GM...');
            const favoris = loadFavoris();
            const folders = loadFolders();
            const hierarchy = loadFoldersHierarchy();
            const categories = loadCategories();

            console.log('📊 Données récupérées:', {
                totalFavoris: favoris.length,
                totalFolders: folders.length,
                totalCategories: categories.length
            });

            // Organiser par dossier
            dataByFolder = {};

            favoris.forEach(fav => {
                if (!dataByFolder[fav.folder]) {
                    dataByFolder[fav.folder] = {
                        folderInfo: hierarchy[fav.folder] || { name: fav.folder },
                        categories: {},
                        total: 0
                    };
                }

                const folderData = dataByFolder[fav.folder];
                folderData.total++;

                // Organiser par catégorie
                const categoryName = fav.categorie || 'Sans catégorie';
                if (!folderData.categories[categoryName]) {
                    folderData.categories[categoryName] = [];
                }

                folderData.categories[categoryName].push({
                    nom: fav.nom,
                    repere: fav.repere || '',
                    commentaire: fav.commentaire || '',
                    timestamp: fav.timestamp || ''
                });
            });
        } else {
            console.log('✅ Données extraites du DOM avec succès!');
        }

        return {
            dataByFolder,
            summary: {
                totalFavoris: Object.values(dataByFolder).reduce((sum, f) => sum + f.total, 0),
                totalFolders: Object.keys(dataByFolder).length,
                totalCategories: new Set(
                    Object.values(dataByFolder).flatMap(f => Object.keys(f.categories))
                ).size,
                folders: Object.keys(dataByFolder).sort()
            }
        };
    }

    // ===== AFFICHAGE DES DONNÉES =====
    
    function displayData() {
        const { dataByFolder, summary } = organizeData();

        console.log('\n📁 ===== RÉSUMÉ =====');
        console.log(`Total des favoris: ${summary.totalFavoris}`);
        console.log(`Total des dossiers: ${summary.totalFolders}`);
        console.log(`Total des catégories: ${summary.totalCategories}`);
        console.log('\n📂 Liste des dossiers:');
        summary.folders.forEach(f => console.log(`  - ${f}`));

        console.log('\n\n📋 ===== DÉTAILS PAR DOSSIER =====\n');

        Object.keys(dataByFolder).sort().forEach(folderKey => {
            const folder = dataByFolder[folderKey];
            console.log(`\n${'='.repeat(80)}`);
            console.log(`📁 DOSSIER: ${folderKey}`);
            console.log(`   Total: ${folder.total} composant(s)`);
            console.log(`${'='.repeat(80)}`);

            Object.keys(folder.categories).sort().forEach(categoryName => {
                const items = folder.categories[categoryName];
                console.log(`\n  🏷️  Catégorie: ${categoryName} (${items.length} composant(s))`);
                console.log(`  ${'-'.repeat(76)}`);

                items.forEach((item, index) => {
                    console.log(`\n  ${index + 1}. ${item.nom}`);
                    if (item.repere) {
                        console.log(`     📌 Repère: ${item.repere}`);
                    }
                    if (item.commentaire) {
                        console.log(`     💬 Commentaire: ${item.commentaire}`);
                    }
                    if (item.timestamp) {
                        const date = new Date(item.timestamp);
                        console.log(`     📅 Ajouté le: ${date.toLocaleString('fr-FR')}`);
                    }
                });
            });
            console.log('\n');
        });

        return { dataByFolder, summary };
    }

    // ===== FONCTION POUR EXPORTER EN JSON =====
    
    function exportToJSON() {
        const favoris = loadFavoris();
        const folders = loadFolders();
        const hierarchy = loadFoldersHierarchy();
        const categories = loadCategories();

        const exportData = {
            exportDate: new Date().toISOString(),
            version: '1.0',
            data: {
                favoris: favoris,
                folders: folders,
                hierarchy: hierarchy,
                categories: categories
            }
        };

        const dataStr = JSON.stringify(exportData, null, 2);
        const dataBlob = new Blob([dataStr], { type: 'application/json' });
        const url = URL.createObjectURL(dataBlob);
        
        const link = document.createElement('a');
        link.href = url;
        link.download = `favoris_backup_${new Date().toISOString().split('T')[0]}.json`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);

        console.log('✅ Export JSON créé avec succès!');
    }

    // ===== FONCTION POUR CRÉER UN TABLEAU HTML =====
    
    function displayHTMLTable() {
        const { dataByFolder } = organizeData();

        let html = `
        <div style="
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            max-width: 1200px;
            max-height: 90vh;
            background: #1e1e1e;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            z-index: 999999;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        ">
            <div style="
                background: linear-gradient(135deg, #2a2a2a 0%, #1f1f1f 100%);
                padding: 20px 30px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                display: flex;
                justify-content: space-between;
                align-items: center;
            ">
                <h2 style="margin: 0; color: #fff; font-size: 24px;">📊 Favoris Composants</h2>
                <div style="display: flex; gap: 10px;">
                    <button id="export-json-btn" style="
                        padding: 8px 16px;
                        background: #4caf50;
                        border: none;
                        border-radius: 6px;
                        color: white;
                        cursor: pointer;
                        font-weight: 600;
                    ">💾 Exporter JSON</button>
                    <button id="close-table-btn" style="
                        padding: 8px 16px;
                        background: #f44336;
                        border: none;
                        border-radius: 6px;
                        color: white;
                        cursor: pointer;
                        font-weight: 600;
                    ">✕ Fermer</button>
                </div>
            </div>
            <div style="
                flex: 1;
                overflow-y: auto;
                padding: 20px 30px;
            ">
        `;

        Object.keys(dataByFolder).sort().forEach(folderKey => {
            const folder = dataByFolder[folderKey];
            html += `
                <div style="margin-bottom: 30px;">
                    <h3 style="
                        color: #4a90e2;
                        margin: 0 0 15px 0;
                        padding: 10px;
                        background: rgba(74,144,226,0.1);
                        border-left: 4px solid #4a90e2;
                        border-radius: 4px;
                    ">📁 ${folderKey} (${folder.total} composant(s))</h3>
            `;

            Object.keys(folder.categories).sort().forEach(categoryName => {
                const items = folder.categories[categoryName];
                html += `
                    <div style="margin-left: 20px; margin-bottom: 20px;">
                        <h4 style="color: #ab47bc; margin: 10px 0;">🏷️ ${categoryName}</h4>
                        <table style="
                            width: 100%;
                            border-collapse: collapse;
                            background: rgba(255,255,255,0.05);
                            border-radius: 8px;
                            overflow: hidden;
                        ">
                            <thead>
                                <tr style="background: rgba(255,255,255,0.1);">
                                    <th style="padding: 12px; text-align: left; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.1);">Composant</th>
                                    <th style="padding: 12px; text-align: left; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.1);">Repère</th>
                                    <th style="padding: 12px; text-align: left; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.1);">Commentaire</th>
                                </tr>
                            </thead>
                            <tbody>
                `;

                items.forEach(item => {
                    html += `
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td style="padding: 10px; color: #e0e0e0;">${item.nom}</td>
                            <td style="padding: 10px; color: #ffc107; font-weight: 600;">${item.repere || '-'}</td>
                            <td style="padding: 10px; color: #9e9e9e; font-size: 13px; white-space: pre-wrap;">${item.commentaire || '-'}</td>
                        </tr>
                    `;
                });

                html += `
                            </tbody>
                        </table>
                    </div>
                `;
            });

            html += `</div>`;
        });

        html += `
            </div>
        </div>
        `;

        const container = document.createElement('div');
        container.id = 'favoris-table-container';
        container.innerHTML = html;
        document.body.appendChild(container);

        // Événements
        document.getElementById('close-table-btn').addEventListener('click', () => {
            container.remove();
        });

        document.getElementById('export-json-btn').addEventListener('click', () => {
            exportToJSON();
        });
    }

    // ===== BOUTON FLOTTANT =====
    
    function createFloatingButton() {
        const button = document.createElement('button');
        button.innerHTML = '📊';
        button.title = 'Afficher les favoris';
        button.style.cssText = `
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
            border: none;
            color: white;
            font-size: 28px;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(74,144,226,0.4);
            z-index: 999998;
            transition: all 0.3s;
        `;

        button.addEventListener('mouseenter', () => {
            button.style.transform = 'scale(1.1)';
            button.style.boxShadow = '0 6px 30px rgba(74,144,226,0.6)';
        });

        button.addEventListener('mouseleave', () => {
            button.style.transform = 'scale(1)';
            button.style.boxShadow = '0 4px 20px rgba(74,144,226,0.4)';
        });

        button.addEventListener('click', () => {
            displayHTMLTable();
        });

        document.body.appendChild(button);
    }

    // ===== INITIALISATION =====
    
    function init() {
        console.log('🚀 SyncFavoris initialisé');
        
        // Attendre que la liste des composants soit chargée
        const checkComponentsList = setInterval(() => {
            const componentsList = document.getElementById('components-list');
            if (componentsList && componentsList.querySelectorAll('.component-card').length > 0) {
                clearInterval(checkComponentsList);
                console.log('✅ Liste des composants détectée!');
                
                // Afficher les données dans la console
                displayData();
                
                // Créer le bouton flottant
                createFloatingButton();
                console.log('✅ Bouton flottant créé. Cliquez dessus pour voir l\'interface!');
            }
        }, 500);
        
        // Timeout après 30 secondes si rien n'est trouvé
        setTimeout(() => {
            clearInterval(checkComponentsList);
            console.log('⏱️ Timeout - Tentative d\'affichage avec les données disponibles...');
            displayData();
            createFloatingButton();
        }, 30000);

        // Exposer les fonctions pour utilisation dans la console
        window.syncFavoris = {
            loadFavoris,
            loadFolders,
            loadFoldersHierarchy,
            loadCategories,
            extractDataFromDOM,
            displayData,
            exportToJSON,
            displayHTMLTable
        };

        console.log('\n💡 Vous pouvez utiliser les fonctions suivantes dans la console:');
        console.log('   - window.syncFavoris.extractDataFromDOM()  : Extraire depuis le DOM');
        console.log('   - window.syncFavoris.displayData()         : Afficher les données dans la console');
        console.log('   - window.syncFavoris.exportToJSON()        : Exporter en JSON');
        console.log('   - window.syncFavoris.displayHTMLTable()    : Afficher le tableau HTML');
    }

    // Attendre que le DOM soit prêt
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

})();
